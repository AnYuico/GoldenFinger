<Window x:Class="GameToolOrchestrator.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}" Height="820" Width="1280"
        MinHeight="720" MinWidth="1100">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="10" BorderBrush="#D0D7DE" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Config" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox Grid.Column="1" Text="{Binding ConfigPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanBrowseConfig, Mode=OneWay}" MinWidth="360" />
                <Button Grid.Column="2" Content="Browse" Click="BrowseConfig_Click" IsEnabled="{Binding CanBrowseConfig, Mode=OneWay}" Margin="8,0,0,0" Padding="12,4" />
                <Button Grid.Column="3" Content="Refresh Config" Command="{Binding RefreshConfigCommand}" Margin="8,0,0,0" Padding="12,4" />
                <Button Grid.Column="4" Content="Save Config" Command="{Binding SaveConfigCommand}" Margin="8,0,0,0" Padding="12,4" />
                <Button Grid.Column="5" Content="Start" Command="{Binding StartExecutionCommand}" Margin="16,0,0,0" Padding="16,4" />
                <Button Grid.Column="6" Content="Cancel" Command="{Binding CancelExecutionCommand}" Margin="8,0,0,0" Padding="16,4" />
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Text="{Binding StatusMessage, Mode=OneWay}" />
            <Separator />
            <TextBlock Text="{Binding DirtyStatusText, Mode=OneWay}" FontWeight="SemiBold" Foreground="#B54708" />
            <Separator />
            <TextBlock Text="Current Tool:" />
            <TextBlock Text="{Binding CurrentTool, Mode=OneWay}" FontWeight="SemiBold" />
            <Separator />
            <TextBlock Text="Current Action:" />
            <TextBlock Text="{Binding CurrentAction, Mode=OneWay}" FontWeight="SemiBold" />
        </StatusBar>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="260" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="420" />
                </Grid.ColumnDefinitions>

                <GroupBox Header="Task Plans" Grid.Column="0">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,4,4,6">
                            <Button Content="Add" Command="{Binding AddTaskPlanCommand}" Padding="8,3" />
                            <Button Content="Copy" Command="{Binding CopyTaskPlanCommand}" Margin="6,0,0,0" Padding="8,3" />
                            <Button Content="Delete" Command="{Binding DeleteTaskPlanCommand}" Margin="6,0,0,0" Padding="8,3" />
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding TaskPlans}"
                                  SelectedItem="{Binding SelectedTaskPlan}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Id" Binding="{Binding Id, Mode=OneWay}" Width="*" />
                                <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=OneWay}" Width="*" />
                                <DataGridTextColumn Header="Enabled" Binding="{Binding EnabledText, Mode=OneWay}" Width="70" IsReadOnly="True" />
                                <DataGridTextColumn Header="Steps" Binding="{Binding StepCount, Mode=OneWay}" Width="55" IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </GroupBox>

                <GroupBox Header="Steps" Grid.Column="2">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,4,4,6">
                            <Button Content="Add Step" Command="{Binding AddStepCommand}" Padding="8,3" />
                            <Button Content="Copy" Command="{Binding CopyStepCommand}" Margin="6,0,0,0" Padding="8,3" />
                            <Button Content="Delete" Command="{Binding DeleteStepCommand}" Margin="6,0,0,0" Padding="8,3" />
                            <Button Content="Normalize Order" Command="{Binding NormalizeStepOrderCommand}" Margin="12,0,0,0" Padding="8,3" />
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding Steps}"
                                  SelectedItem="{Binding SelectedStep}"
                                  AutoGenerateColumns="False"
                                  SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Order" Binding="{Binding Order, Mode=OneWay}" Width="60" IsReadOnly="True" />
                                <DataGridTextColumn Header="Tool Id" Binding="{Binding ToolId, Mode=OneWay}" Width="110" IsReadOnly="True" />
                                <DataGridTextColumn Header="Tool" Binding="{Binding ToolName, Mode=OneWay}" Width="140" IsReadOnly="True" />
                                <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status, Mode=OneWay}" Width="110" IsReadOnly="True" />
                                <DataGridTextColumn Header="Last Error" Binding="{Binding LastError, Mode=OneWay}" Width="*" IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </GroupBox>

                <Grid Grid.Column="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="260" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="260" />
                    </Grid.RowDefinitions>

                    <GroupBox Header="Tools" Grid.Row="0" Margin="0,0,0,8">
                        <DockPanel Margin="8">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                <Button Content="Add Tool" Command="{Binding AddToolCommand}" Padding="8,3" />
                                <Button Content="Copy" Command="{Binding CopyToolCommand}" Margin="6,0,0,0" Padding="8,3" />
                                <Button Content="Delete" Command="{Binding DeleteToolCommand}" Margin="6,0,0,0" Padding="8,3" />
                            </StackPanel>
                            <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Tool Id" Grid.Row="0" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedTool.Id, Mode=OneWay}" FontWeight="SemiBold" />
                                <TextBlock Text="Tool Name" Grid.Row="1" VerticalAlignment="Center" Margin="0,6,0,0" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedTool.Name, Mode=OneWay}" FontWeight="SemiBold" Margin="0,6,0,0" />
                                <TextBlock Text="Executable" Grid.Row="2" VerticalAlignment="Center" Margin="0,6,0,0" />
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SelectedTool.ExecutablePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding HasSelectedTool, Mode=OneWay}" Margin="0,6,0,0" />
                                <TextBlock Text="Working Dir" Grid.Row="3" VerticalAlignment="Center" Margin="0,6,0,0" />
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SelectedTool.WorkingDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding HasSelectedTool, Mode=OneWay}" Margin="0,6,0,0" />
                            </Grid>
                            <DataGrid ItemsSource="{Binding Tools}"
                                      SelectedItem="{Binding SelectedTool}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Id" Binding="{Binding Id, Mode=OneWay}" Width="110" />
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=OneWay}" Width="*" />
                                    <DataGridTextColumn Header="Type" Binding="{Binding Type, Mode=OneWay}" Width="90" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </GroupBox>

                    <GroupBox Header="Actions" Grid.Row="1" Margin="0,0,0,8">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,4,4,6">
                                <ComboBox ItemsSource="{Binding SupportedActionTypes}"
                                          SelectedItem="{Binding SelectedNewActionType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Width="150" />
                                <Button Content="Add Action" Command="{Binding AddActionCommand}" Margin="6,0,0,0" Padding="8,3" />
                                <Button Content="Copy" Command="{Binding CopyActionCommand}" Margin="6,0,0,0" Padding="8,3" />
                                <Button Content="Delete" Command="{Binding DeleteActionCommand}" Margin="6,0,0,0" Padding="8,3" />
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding Actions}"
                                      SelectedItem="{Binding SelectedAction}"
                                      AutoGenerateColumns="False"
                                      SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Index, Mode=OneWay}" Width="40" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Type" Binding="{Binding Type, Mode=OneWay}" Width="120" IsReadOnly="True" />
                                    <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                                    <DataGridTextColumn Header="Summary" Binding="{Binding Summary, Mode=OneWay}" Width="*" IsReadOnly="True" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </GroupBox>

                    <GroupBox Header="Action Editor" Grid.Row="2">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8" DataContext="{Binding SelectedActionEditor}">
                                <TextBlock Text="{Binding UnsupportedMessage}" Foreground="#B54708" TextWrapping="Wrap"
                                           Visibility="{Binding IsUnsupportedEditor, Converter={StaticResource BoolToVisibilityConverter}}" />

                                <Grid Visibility="{Binding IsSupportedEditor, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Text="Type" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Type, Mode=OneWay}" FontWeight="SemiBold" />

                                    <TextBlock Grid.Row="1" Text="Enabled" VerticalAlignment="Center" Margin="0,6,8,0" />
                                    <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" />

                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Visibility="{Binding IsWaitSecondsEditor, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="Seconds" Margin="0,8,0,0" />
                                        <TextBox Text="{Binding Seconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Timeout Seconds" Margin="0,8,0,0" />
                                        <TextBox Text="{Binding TimeoutSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="{Binding TimeoutRuleHint, Mode=OneWay}" Foreground="#57606A" TextWrapping="Wrap" Margin="0,6,0,0" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Visibility="{Binding IsWaitProcessExitEditor, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="Timeout Seconds" Margin="0,8,0,0" />
                                        <TextBox Text="{Binding TimeoutSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Timeout Minutes" Margin="0,8,0,0" />
                                        <TextBox Text="{Binding TimeoutMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="{Binding TimeoutRuleHint, Mode=OneWay}" Foreground="#57606A" TextWrapping="Wrap" Margin="0,6,0,0" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Visibility="{Binding IsWaitWindowEditor, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="Title Equals" Margin="0,8,0,0" />
                                        <TextBox Text="{Binding TitleEquals, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Title Contains" Margin="0,8,0,0" />
                                        <TextBox Text="{Binding TitleContains, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Timeout Seconds" Margin="0,8,0,0" />
                                        <TextBox Text="{Binding TimeoutSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="{Binding TitlePriorityHint, Mode=OneWay}" Foreground="#57606A" TextWrapping="Wrap" Margin="0,6,0,0" />
                                        <TextBlock Text="{Binding TimeoutRuleHint, Mode=OneWay}" Foreground="#57606A" TextWrapping="Wrap" Margin="0,6,0,0" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Visibility="{Binding IsClickButtonEditor, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="Window Title Contains" Margin="0,8,0,0" />
                                        <TextBox Text="{Binding WindowTitleContains, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="AutomationId" Margin="0,8,0,0" />
                                        <TextBox Text="{Binding AutomationId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Name Equals" Margin="0,8,0,0" />
                                        <TextBox Text="{Binding NameEquals, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Name Contains" Margin="0,8,0,0" />
                                        <TextBox Text="{Binding NameContains, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Control Type" Margin="0,8,0,0" />
                                        <TextBox Text="{Binding ControlType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Timeout Seconds" Margin="0,8,0,0" />
                                        <TextBox Text="{Binding TimeoutSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="{Binding SelectorPriorityHint, Mode=OneWay}" Foreground="#57606A" TextWrapping="Wrap" Margin="0,6,0,0" />
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button Content="用当前 Selector 测试" Command="{Binding TestSelectorCommand}" Padding="8,4" />
                                            <Button Content="测试并点击" Command="{Binding TestSelectorAndClickCommand}" Margin="8,0,0,0" Padding="8,4" />
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Text="{Binding ValidationMessage, Mode=OneWay}" Foreground="#B42318" TextWrapping="Wrap" Margin="0,8,0,0" />
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </GroupBox>
                </Grid>
            </Grid>

            <Grid Grid.Row="1" Margin="10,0,10,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <GroupBox Header="Diagnostics" Grid.Column="0">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Row="0" Grid.ColumnSpan="2" Content="Refresh Window List" Command="{Binding RefreshWindowsCommand}" Padding="8,4" />

                        <TextBlock Grid.Row="1" Text="Tree Title" VerticalAlignment="Center" Margin="0,8,8,0" />
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DiagnosticTitleContains, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" />
                        <Button Grid.Row="2" Grid.ColumnSpan="2" Content="Export Control Tree" Command="{Binding ExportControlTreeCommand}" Margin="0,8,0,0" Padding="8,4" />

                        <TextBlock Grid.Row="3" Text="Window Title" VerticalAlignment="Center" Margin="0,8,8,0" />
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding DiagnosticWindowTitleContains, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" />
                        <TextBlock Grid.Row="4" Text="AutomationId" VerticalAlignment="Center" Margin="0,8,8,0" />
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding DiagnosticAutomationId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,0" />
                        <TextBlock Grid.Row="5" Text="Name Contains" VerticalAlignment="Top" Margin="0,8,8,0" />
                        <DockPanel Grid.Row="5" Grid.Column="1" Margin="0,8,0,0">
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Test Selector" Command="{Binding TestSelectorCommand}" Padding="8,4" />
                                <Button Content="Test And Click" Command="{Binding TestSelectorAndClickCommand}" Margin="8,0,0,0" Padding="8,4" />
                            </StackPanel>
                            <TextBox Text="{Binding DiagnosticNameContains, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Logs" Grid.Column="2">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="复制诊断信息" Command="{Binding CopyDiagnosticsCommand}" Padding="8,4" />
                            <Button Content="打开日志文件夹" Command="{Binding OpenLogsFolderCommand}" Margin="8,0,0,0" Padding="8,4" />
                            <Button Content="打开配置文件夹" Command="{Binding OpenConfigFolderCommand}" Margin="8,0,0,0" Padding="8,4" />
                        </StackPanel>
                        <ListBox ItemsSource="{Binding Logs}" FontFamily="Consolas" FontSize="12" />
                    </DockPanel>
                </GroupBox>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
